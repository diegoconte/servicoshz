<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal de Atendimento e Carta de Serviços - Horizontina</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sp-yellow': '#ffe400',
                        'sp-blue': '#002B5E',
                        'sp-gray': '#f5f5f5',
                        'sp-dark': '#333333'
                    }
                }
            }
        }
    </script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .page-section { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hidden-section { display: none !important; }
        
        /* Estilo para a barra de rolagem dos filtros */
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans flex flex-col min-h-screen">

    <!-- Topo de Acessibilidade -->
    <div class="w-full bg-white py-2 px-4 flex justify-end items-center gap-4 text-sm border-b border-gray-200">
        <div class="flex items-center gap-3 mr-4 hidden sm:flex">
            <button class="hover:underline font-bold" aria-label="Aumentar texto">A+</button>
            <button class="hover:underline font-bold" aria-label="Diminuir texto">A-</button>
            <button class="hover:text-gray-600" aria-label="Alto Contraste"><i class="fas fa-adjust"></i></button>
        </div>
        <button class="bg-gray-200 hover:bg-gray-300 px-4 py-1 rounded-full text-gray-700 font-semibold transition">
            <i class="fas fa-sign-in-alt mr-2"></i> ENTRE
        </button>
    </div>

    <!-- Cabeçalho Principal -->
    <header class="bg-white border-b border-gray-200">
        <div class="container mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-4 cursor-pointer" onclick="showPage('home')">
                <div class="w-16 h-20 bg-gray-100 border border-gray-300 rounded-lg flex items-center justify-center shadow-sm">
                    <i class="fas fa-shield-alt text-3xl text-gray-400"></i>
                </div>
                <div>
                    <h1 class="text-sm font-bold text-gray-800 leading-tight">PREFEITURA DE</h1>
                    <h2 class="text-2xl font-extrabold text-sp-blue leading-tight uppercase">Horizontina</h2>
                    <div class="flex items-center gap-1 mt-1">
                        <span class="bg-sp-yellow text-black font-bold text-xs px-1 rounded">156</span>
                        <span class="text-sm font-semibold text-gray-600">CARTA DE SERVIÇOS</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Menu de Navegação Secundário -->
    <nav class="bg-sp-blue text-white shadow-md sticky top-0 z-40">
        <div class="container mx-auto flex overflow-x-auto text-sm font-semibold uppercase">
            <button onclick="showPage('home')" id="nav-home" class="nav-link px-6 py-4 transition bg-sp-yellow text-black">Início</button>
            <button onclick="showPage('carta')" id="nav-carta" class="nav-link px-6 py-4 transition hover:bg-blue-800">Todos os Serviços</button>
            <button onclick="showPage('acompanhar')" id="nav-acompanhar" class="nav-link px-6 py-4 transition hover:bg-blue-800">Acompanhar Protocolo</button>
        </div>
    </nav>

    <!-- CONTEÚDO PRINCIPAL -->
    <main class="container mx-auto px-4 py-8 flex-grow">
        
        <!-- ========================================== -->
        <!-- PÁGINA 1: INÍCIO (DESTAQUES)               -->
        <!-- ========================================== -->
        <div id="page-home" class="page-section">
            
            <!-- Barra de Busca Rápida -->
            <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200 mb-10 text-center">
                <h2 class="text-2xl font-bold mb-2">O que você está buscando?</h2>
                <p class="text-gray-600 mb-6">Encontre serviços, informações e formulários da Prefeitura.</p>
                <div class="max-w-2xl mx-auto flex flex-col sm:flex-row shadow-sm">
                    <input type="text" id="busca-home" placeholder="Ex: Alvará, Iluminação, IPTU..." class="w-full border border-gray-300 px-6 py-4 rounded-t-md sm:rounded-l-md sm:rounded-tr-none focus:outline-none focus:border-sp-blue text-lg">
                    <button onclick="buscarDaHome()" class="bg-sp-blue text-white px-8 py-4 hover:bg-blue-900 transition sm:rounded-r-md sm:rounded-bl-none rounded-b-md font-bold text-lg">
                        <i class="fas fa-search mr-2"></i> Buscar
                    </button>
                </div>
            </div>

            <h3 class="text-2xl font-bold text-gray-900 mb-6 border-b-2 border-sp-yellow inline-block pb-1">Serviços Mais Procurados</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="grid-destaques">
                <!-- Preenchido via JavaScript -->
            </div>
            
            <div class="text-center mt-8">
                <button onclick="showPage('carta')" class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 px-8 rounded-full transition shadow-sm">
                    Ver Todos os Serviços da Carta <i class="fas fa-arrow-right ml-2"></i>
                </button>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- PÁGINA 2: CARTA DE SERVIÇOS (FILTROS)      -->
        <!-- ========================================== -->
        <div id="page-carta" class="page-section hidden-section">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Carta de Serviços ao Cidadão</h2>
            
            <div class="flex flex-col md:flex-row gap-8">
                <!-- Sidebar de Filtros -->
                <aside class="w-full md:w-1/4 bg-white p-6 rounded-lg shadow-sm border border-gray-200 h-fit">
                    <h3 class="font-bold text-lg mb-4 flex items-center gap-2"><i class="fas fa-filter text-sp-blue"></i> Filtros</h3>
                    
                    <div class="mb-6">
                        <label class="block text-sm font-bold text-gray-700 mb-2">Busca por Palavra</label>
                        <input type="text" id="input-busca" placeholder="Filtrar serviços..." class="w-full border border-gray-300 px-3 py-2 rounded focus:outline-none focus:border-sp-blue" onkeyup="aplicarFiltros()">
                    </div>

                    <div class="mb-6">
                        <h4 class="font-bold text-sm text-gray-700 mb-3 border-b pb-1">Por Secretaria</h4>
                        <div class="space-y-2 max-h-48 overflow-y-auto custom-scrollbar text-sm" id="filtros-secretaria">
                            <!-- Preenchido via JS -->
                        </div>
                    </div>

                    <div class="mb-6">
                        <h4 class="font-bold text-sm text-gray-700 mb-3 border-b pb-1">Custo do Serviço</h4>
                        <div class="space-y-2 text-sm">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" class="filtro-custo rounded text-sp-blue" value="gratuito" onchange="aplicarFiltros()"> Gratuito
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" class="filtro-custo rounded text-sp-blue" value="pago" onchange="aplicarFiltros()"> Possui Taxas/Custos
                            </label>
                        </div>
                    </div>
                </aside>

                <!-- Área de Resultados (Lista de Serviços) -->
                <div class="w-full md:w-3/4">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-gray-600 font-semibold" id="contador-resultados">Mostrando 0 serviços</span>
                    </div>
                    <div class="grid grid-cols-1 gap-4" id="lista-servicos">
                        <!-- Preenchido via JavaScript -->
                    </div>
                </div>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- PÁGINA 3: DETALHE DO SERVIÇO (PDF MODELO)  -->
        <!-- ========================================== -->
        <div id="page-detalhe" class="page-section hidden-section">
            <button onclick="showPage('carta')" class="text-sp-blue font-bold hover:underline mb-6 flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> Voltar para a lista de serviços
            </button>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <!-- Cabeçalho do Serviço -->
                <div class="bg-sp-blue text-white p-8">
                    <span id="det-secretaria" class="bg-blue-800 text-blue-100 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Secretaria</span>
                    <h2 id="det-titulo" class="text-3xl font-bold mt-4 mb-2">Nome do Serviço</h2>
                    <div class="flex flex-wrap gap-4 mt-4 text-sm font-medium">
                        <span id="det-custo-badge" class="bg-green-500 text-white px-3 py-1 rounded-md flex items-center gap-2"><i class="fas fa-dollar-sign"></i> Gratuito</span>
                        <span id="det-publico-badge" class="bg-blue-700 text-white px-3 py-1 rounded-md flex items-center gap-2"><i class="fas fa-users"></i> Público</span>
                    </div>
                </div>

                <div class="p-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Coluna Principal (Descrição, Documentos, Etapas) -->
                    <div class="lg:col-span-2 space-y-8">
                        
                        <section>
                            <h3 class="text-xl font-bold text-gray-900 border-b-2 border-sp-yellow pb-2 mb-4 flex items-center gap-2">
                                <i class="fas fa-info-circle text-sp-blue"></i> O que é?
                            </h3>
                            <p id="det-descricao" class="text-gray-700 leading-relaxed"></p>
                        </section>

                        <section>
                            <h3 class="text-xl font-bold text-gray-900 border-b-2 border-sp-yellow pb-2 mb-4 flex items-center gap-2">
                                <i class="far fa-id-card text-sp-blue"></i> Quem pode solicitar? (Elegibilidade)
                            </h3>
                            <p id="det-elegibilidade" class="text-gray-700 leading-relaxed"></p>
                        </section>

                        <section>
                            <h3 class="text-xl font-bold text-gray-900 border-b-2 border-sp-yellow pb-2 mb-4 flex items-center gap-2">
                                <i class="fas fa-file-alt text-sp-blue"></i> Documentação Exigida
                            </h3>
                            <ul id="det-documentos" class="list-disc list-inside text-gray-700 space-y-2 bg-gray-50 p-4 rounded-lg border border-gray-100">
                                <!-- Preenchido via JS -->
                            </ul>
                        </section>

                        <section>
                            <h3 class="text-xl font-bold text-gray-900 border-b-2 border-sp-yellow pb-2 mb-4 flex items-center gap-2">
                                <i class="fas fa-shoe-prints text-sp-blue"></i> Etapas do Processo
                            </h3>
                            <div id="det-etapas" class="space-y-4">
                                <!-- Preenchido via JS com design de "stepper" -->
                            </div>
                        </section>
                    </div>

                    <!-- Coluna Lateral (Prazos, Canais, Custos) -->
                    <div class="space-y-6">
                        
                        <!-- Ação Principal -->
                        <div id="det-area-online" class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center hidden">
                            <h4 class="font-bold text-lg text-gray-900 mb-2">Serviço Digital</h4>
                            <p class="text-sm text-gray-600 mb-4">Você pode solicitar este serviço diretamente pela internet.</p>
                            <a href="#" id="det-link-online" class="block w-full bg-sp-blue hover:bg-blue-900 text-white font-bold py-3 px-4 rounded transition">
                                Solicitar Online <i class="fas fa-external-link-alt ml-1"></i>
                            </a>
                        </div>

                        <!-- Canais de Atendimento -->
                        <div class="bg-gray-50 border border-gray-200 p-6 rounded-lg">
                            <h4 class="font-bold text-gray-900 mb-4 border-b pb-2"><i class="fas fa-map-marker-alt text-red-500 mr-2"></i> Onde solicitar?</h4>
                            <div id="det-canais" class="text-sm text-gray-700 space-y-3">
                                <!-- Preenchido via JS -->
                            </div>
                        </div>

                        <!-- Prazos -->
                        <div class="bg-gray-50 border border-gray-200 p-6 rounded-lg">
                            <h4 class="font-bold text-gray-900 mb-4 border-b pb-2"><i class="far fa-clock text-blue-500 mr-2"></i> Prazos</h4>
                            <ul class="text-sm text-gray-700 space-y-3">
                                <li class="flex justify-between border-b border-gray-200 pb-2">
                                    <span class="text-gray-500">Tempo de Espera:</span>
                                    <strong id="det-prazo-espera"></strong>
                                </li>
                                <li class="flex justify-between border-b border-gray-200 pb-2">
                                    <span class="text-gray-500">Prazo de Análise:</span>
                                    <strong id="det-prazo-analise"></strong>
                                </li>
                                <li class="flex justify-between">
                                    <span class="text-gray-500">Prazo Total Máximo:</span>
                                    <strong id="det-prazo-total"></strong>
                                </li>
                            </ul>
                        </div>

                        <!-- Custos detalhados -->
                        <div class="bg-gray-50 border border-gray-200 p-6 rounded-lg">
                            <h4 class="font-bold text-gray-900 mb-4 border-b pb-2"><i class="fas fa-coins text-yellow-600 mr-2"></i> Custos e Taxas</h4>
                            <p id="det-custos-desc" class="text-sm text-gray-700"></p>
                        </div>
                        
                        <!-- Resultado -->
                        <div class="bg-gray-50 border border-gray-200 p-6 rounded-lg">
                            <h4 class="font-bold text-gray-900 mb-4 border-b pb-2"><i class="fas fa-check-circle text-green-500 mr-2"></i> O que eu recebo?</h4>
                            <p id="det-resultado" class="text-sm text-gray-700"></p>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- Rodapé -->
    <footer class="bg-sp-blue text-white py-8 border-t-4 border-sp-yellow mt-auto">
        <div class="container mx-auto px-4 text-center">
            <h3 class="font-bold text-lg mb-2">Prefeitura Municipal de Horizontina</h3>
            <p class="text-sm text-gray-300">Ouvidoria Municipal | Ação de Transparência e Governança - Lei nº 13.460/2017</p>
        </div>
    </footer>

    <!-- BANCO DE DADOS SIMULADO & LÓGICA -->
