        // 2. Funções de Navegação de Telas
        function showPage(pageId) {
            document.querySelectorAll('.page-section').forEach(sec => sec.classList.add('hidden-section'));
            document.getElementById('page-' + pageId).classList.remove('hidden-section');
            
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('bg-sp-yellow', 'text-black');
                if(!link.classList.contains('hover:bg-blue-800')) link.classList.add('hover:bg-blue-800');
            });
            
            const activeNav = document.getElementById('nav-' + pageId);
            if(activeNav) {
                activeNav.classList.remove('hover:bg-blue-800');
                activeNav.classList.add('bg-sp-yellow', 'text-black');
            }

            if(pageId === 'home') renderDestaques();
            if(pageId === 'carta') renderListaServicos();
        }

        // 3. Renderização na Home (Destaques)
        function renderDestaques() {
            const grid = document.getElementById('grid-destaques');
            grid.innerHTML = '';
            
            const destaques = bdServicos.filter(s => s.destaque);
            
            destaques.forEach(serv => {
                const card = document.createElement('div');
                card.className = "bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md transition flex flex-col p-6 cursor-pointer";
                card.onclick = () => abrirDetalhe(serv.id);
                card.innerHTML = `
                    <span class="text-xs font-bold text-sp-blue uppercase mb-2 block">${serv.secretaria}</span>
                    <h4 class="font-bold text-lg mb-3 flex-grow text-gray-900 line-clamp-2">${serv.titulo}</h4>
                    <span class="text-sm ${serv.custo.gratuito ? 'text-green-600' : 'text-yellow-600'} font-semibold mb-4 block">
                        <i class="fas ${serv.custo.gratuito ? 'fa-check' : 'fa-dollar-sign'}"></i> ${serv.custo.gratuito ? 'Gratuito' : 'Com Custo'}
                    </span>
                    <button class="w-full bg-gray-100 hover:bg-sp-yellow hover:text-black text-gray-800 font-bold py-2 px-4 rounded transition border border-gray-200">
                        Ver Detalhes
                    </button>
                `;
                grid.appendChild(card);
            });
        }

        // 4. Lógica da Carta de Serviços (Filtros e Lista)
        function extrairSecretarias() {
            const secretarias = [...new Set(bdServicos.map(s => s.secretaria))].sort();
            const container = document.getElementById('filtros-secretaria');
            container.innerHTML = '';
            
            secretarias.forEach(sec => {
                container.innerHTML += `
                    <label class="flex items-center gap-2 cursor-pointer mb-2">
                        <input type="checkbox" class="filtro-sec rounded text-sp-blue" value="${sec}" onchange="aplicarFiltros()"> 
                        <span class="leading-tight">${sec}</span>
                    </label>
                `;
            });
        }

        function aplicarFiltros() {
            const termoBusca = document.getElementById('input-busca').value.toLowerCase();
            
            // Pega checkboxes marcados de Secretaria
            const secSelecionadas = Array.from(document.querySelectorAll('.filtro-sec:checked')).map(cb => cb.value);
            
            // Pega checkboxes marcados de Custo
            const custosSelecionados = Array.from(document.querySelectorAll('.filtro-custo:checked')).map(cb => cb.value);

            const resultados = bdServicos.filter(serv => {
                // Filtro de Texto
                const matchTexto = serv.titulo.toLowerCase().includes(termoBusca) || serv.descricao.toLowerCase().includes(termoBusca);
                
                // Filtro de Secretaria
                const matchSec = secSelecionadas.length === 0 || secSelecionadas.includes(serv.secretaria);
                
                // Filtro de Custo
                let matchCusto = true;
                if (custosSelecionados.length > 0) {
                    if (custosSelecionados.includes('gratuito') && custosSelecionados.includes('pago')) {
                        matchCusto = true; // Ambos marcados
                    } else if (custosSelecionados.includes('gratuito')) {
                        matchCusto = serv.custo.gratuito === true;
                    } else if (custosSelecionados.includes('pago')) {
                        matchCusto = serv.custo.gratuito === false;
                    }
                }

                return matchTexto && matchSec && matchCusto;
            });

            renderLista(resultados);
        }

        function renderLista(lista) {
            const container = document.getElementById('lista-servicos');
            document.getElementById('contador-resultados').innerText = `Mostrando ${lista.length} serviço(s)`;
            container.innerHTML = '';

            if(lista.length === 0) {
                container.innerHTML = `<div class="p-8 text-center text-gray-500 bg-white rounded border border-gray-200">Nenhum serviço encontrado com estes filtros.</div>`;
                return;
            }

            lista.forEach(serv => {
                // Identifica se tem atendimento online para destacar
                const temOnline = serv.canais.some(c => c.tipo === "Online");
                const badgeOnline = temOnline ? `<span class="bg-blue-100 text-sp-blue text-xs font-bold px-2 py-1 rounded ml-2"><i class="fas fa-laptop"></i> Solicitação Online</span>` : '';

                const card = document.createElement('div');
                card.className = "bg-white border border-gray-200 p-5 rounded-lg hover:border-sp-blue transition shadow-sm flex flex-col md:flex-row justify-between md:items-center gap-4 cursor-pointer";
                card.onclick = () => abrirDetalhe(serv.id);
                card.innerHTML = `
                    <div class="flex-grow">
                        <span class="text-xs font-bold text-gray-500 uppercase">${serv.secretaria}</span>
                        <h4 class="font-bold text-lg text-sp-blue flex items-center flex-wrap gap-2 mt-1">
                            ${serv.titulo} ${badgeOnline}
                        </h4>
                        <p class="text-sm text-gray-600 mt-2 line-clamp-2">${serv.descricao}</p>
                    </div>
                    <div class="flex-shrink-0 md:text-right">
                        <div class="text-sm font-bold ${serv.custo.gratuito ? 'text-green-600' : 'text-yellow-600'} mb-2">
                            ${serv.custo.gratuito ? 'Gratuito' : 'Com Custo'}
                        </div>
                        <button class="bg-gray-800 text-white hover:bg-gray-700 px-4 py-2 rounded text-sm font-bold w-full md:w-auto transition">
                            Acessar Serviço
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function renderListaServicos() {
            extrairSecretarias();
            aplicarFiltros(); // Renderiza com os filtros iniciais (vazios = todos)
        }

        // Função auxiliar para busca pela Home
        function buscarDaHome() {
            const texto = document.getElementById('busca-home').value;
            showPage('carta');
            document.getElementById('input-busca').value = texto;
            aplicarFiltros();
        }

        // 5. Preencher e Abrir a Tela de Detalhes do Serviço
        function abrirDetalhe(id) {
            const serv = bdServicos.find(s => s.id === id);
            if(!serv) return;

            // Cabeçalho
            document.getElementById('det-titulo').innerText = serv.titulo;
            document.getElementById('det-secretaria').innerText = serv.secretaria;
            
            // Badges
            const badgeCusto = document.getElementById('det-custo-badge');
            badgeCusto.className = `px-3 py-1 rounded-md flex items-center gap-2 ${serv.custo.gratuito ? 'bg-green-500 text-white' : 'bg-yellow-500 text-black'}`;
            badgeCusto.innerHTML = `<i class="fas ${serv.custo.gratuito ? 'fa-check' : 'fa-dollar-sign'}"></i> ${serv.custo.gratuito ? 'Gratuito' : 'Com Custo'}`;
            
            // Textos Principais
            document.getElementById('det-descricao').innerText = serv.descricao;
            document.getElementById('det-elegibilidade').innerText = serv.elegibilidade;
            document.getElementById('det-resultado').innerText = serv.resultado;
            
            // Documentos (Lista)
            const ulDocs = document.getElementById('det-documentos');
            ulDocs.innerHTML = '';
            serv.documentos.forEach(doc => {
                ulDocs.innerHTML += `<li>${doc}</li>`;
            });

            // Etapas (Stepper)
            const divEtapas = document.getElementById('det-etapas');
            divEtapas.innerHTML = '';
            serv.etapas.forEach((etapa, index) => {
                divEtapas.innerHTML += `
                    <div class="flex gap-4">
                        <div class="flex flex-col items-center">
                            <div class="w-8 h-8 rounded-full bg-sp-yellow text-black font-bold flex items-center justify-center shrink-0 z-10 border-2 border-white shadow-sm">${index + 1}</div>
                            ${index < serv.etapas.length - 1 ? '<div class="w-0.5 h-full bg-gray-200 mt-1"></div>' : ''}
                        </div>
                        <div class="pb-6 pt-1">
                            <h5 class="font-bold text-gray-800">${etapa.nome}</h5>
                            <p class="text-sm text-gray-600 mt-1">${etapa.desc}</p>
                        </div>
                    </div>
                `;
            });

            // Prazos
            document.getElementById('det-prazo-espera').innerText = serv.prazos.espera;
            document.getElementById('det-prazo-analise').innerText = serv.prazos.analise;
            document.getElementById('det-prazo-total').innerText = serv.prazos.total;

            // Custos Texto
            document.getElementById('det-custos-desc').innerText = serv.custo.descricao;

            // Canais e Botão Online
            const divCanais = document.getElementById('det-canais');
            divCanais.innerHTML = '';
            
            const areaOnline = document.getElementById('det-area-online');
            const linkOnline = document.getElementById('det-link-online');
            areaOnline.classList.add('hidden'); // esconde por padrão
            
            serv.canais.forEach(canal => {
                let icone = 'fa-map-marker-alt';
                if(canal.tipo === 'Online') icone = 'fa-laptop';
                if(canal.tipo === 'Telefone') icone = 'fa-phone';

                divCanais.innerHTML += `
                    <div class="flex gap-3 mb-2">
                        <i class="fas ${icone} text-gray-400 mt-1"></i>
                        <div>
                            <strong class="block">${canal.tipo}</strong>
                            <span>${canal.local}</span>
                        </div>
                    </div>
                `;

                // Se houver canal online com link, ativa o botão grande em destaque
                if(canal.tipo === 'Online' && canal.link) {
                    areaOnline.classList.remove('hidden');
                    linkOnline.href = canal.link;
                }
            });

            // Mudar a tela
            showPage('detalhe');
            window.scrollTo(0, 0); // Sobe a página para o topo
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', () => {
            showPage('home');
        });

    </script>
</body>
</html>
